{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.dengxuhui/igpsport-mcp",
  "description": "iGPSport cycling data with training metrics (NP/IF/TSS/CTL/ATL/TSB) and workout generation",
  "repository": {
    "url": "https://github.com/dengxuhui/igpsport-mcp",
    "source": "github"
  },
  "version": "0.7.1",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "igpsport-mcp",
      "version": "0.7.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "iGPSport account (phone for CN, email for intl)",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "IGPSPORT_USERNAME"
        },
        {
          "description": "Password",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "IGPSPORT_PASSWORD"
        },
        {
          "description": "Region: cn (default) or intl",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "IGPSPORT_REGION"
        },
        {
          "description": "Functional Threshold Power in watts",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "IGPSPORT_FTP"
        },
        {
          "description": "Lactate Threshold Heart Rate in bpm",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "IGPSPORT_LTHR"
        }
      ]
    }
  ]
}
